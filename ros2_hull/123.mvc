capture_directory: "~"
fixed_frame: map
target_frame: <none>
fix_orientation: true
rotate_90: false
enable_antialiasing: true
show_displays: true
show_status_bar: true
show_capture_tools: true
window_width: 1618
window_height: 767
view_scale: 0.3676011
offset_x: 1211.914
offset_y: 100.9409
use_latest_transforms: true
background: "#787878"
image_transport: raw
force_720p: true
