    name: new display
    config:
      visible: true
      collapsed: false
      custom_sources:
        - base_url: "file:///home/orangepi/Desktop/Hull_control_ststem/ros2_hull/map/{level}/{x}/{y}.png\n"
          max_zoom: 21
          name: 122
          type: wmts
      bing_api_key: ""
